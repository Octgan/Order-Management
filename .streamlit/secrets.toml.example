# 複数端末でデータを共有するための Supabase 設定
# 1. https://supabase.com でプロジェクトを作成
# 2. Storage でバケット「order-app-data」を作成（非公開でOK）
# 3. Project Settings → API の service_role key をコピー
# 4. このファイルを secrets.toml にコピーして値を入れる
#    （Streamlit Cloud の場合はアプリ設定の Secrets に同じ内容を貼る）

[supabase]
url = "https://xxxxxxxx.supabase.co"
key = "your-service-role-key"
bucket = "order-app-data"
